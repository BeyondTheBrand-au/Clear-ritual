  "platform_customizations": {
    "custom_css": [
      "/* ------------------------------------------- */ /* Fully center Horizon Email Signup block including heading */ /* ------------------------------------------- */ /* Center the entire form container */.email-signup,.email-signup__form,.email-signup__input-wrapper {display: flex !important; flex-direction: column; /* stack input and button vertically */ align-items: center !important; /* horizontal centering */ justify-content: center; /* vertical centering if needed */ text-align: center; /* center any text inside */}",
      " /* Center the heading */.email-signup__heading {text-align: center !important; width: 100%; margin-bottom: 10px; /* spacing below heading */}",
      " /* Center input text and placeholder */.email-signup__input {text-align: center !important; /* placeholder and typed text */ max-width: 320px; /* constrain input width */ width: 100%; margin-bottom: 10px; /* space between input and button */}",
      " /* Center the button */.email-signup__button {margin: 0 auto; /* center button horizontally */}",
      " /* Optional: center any label above the input */.email-signup__label {text-align: center !important; margin-bottom: 5px; /* optional spacing */}",
      " /* Mobile tweaks */@media screen and (max-width: 749px) {.email-signup__input {max-width: 100%; /* slightly smaller input on mobile */ }}",
      " /* Prevent Horizon Email Signup block from jumping on submit */.email-signup {scroll-margin-top: 0;}"
    ]
  }
