                      "blocks": {
                        "text_8bTi7B": {
                          "type": "text",
                          "name": "t:names.text",
                          "settings": {
                            "text": "<p>A vibrant burst of juicy flavour! The tropical sweetness of guava and the tangy punch of cherry mingle to create a mouth-watering, fruity profile that perfectly balances the earthy base of the yerba mate.</p>",
                            "width": "fit-content",
