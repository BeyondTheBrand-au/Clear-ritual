              "blocks": {
                "custom_liquid_yfKhJG": {
                  "type": "custom-liquid",
                  "name": "t:names.custom_liquid",
                  "settings": {
                    "custom_liquid": "{% assign product_handle = 'yerba-mate-guarana-loose-leaf-blend' %}\n{% assign ritual_product = all_products[product_handle] %}\n{% assign ritual_variant = ritual_product.selected_or_first_available_variant %}\n\n{% if ritual_product != blank and ritual_variant != blank %}\n  <div class=\"ritual-atc-wrap\">\n    <form class=\"ritual-atc-form\">\n      <input type=\"hidden\" name=\"id\" value=\"{{ ritual_variant.id }}\">\n      <input type=\"hidden\" name=\"quantity\" value=\"1\">\n\n      <button type=\"submit\" class=\"button ritual-atc-button\">\n        START YOUR RITUAL - {{ ritual_variant.price | money }}\n      </button>\n    </form>\n\n    <p class=\"ritual-atc-message\" style=\"display:none;\"></p>\n  </div>\n\n  <script>\n    (() => {\n      const wrapper = document.currentScript.previousElementSibling;\n      if (!wrapper) return;\n\n      const form = wrapper.querySelector('.ritual-atc-form');\n      const button = wrapper.querySelector('.ritual-atc-button');\n      const message = wrapper.querySelector('.ritual-atc-message');\n\n      if (!form || !button || !message) return;\n\n      form.addEventListener('submit', async (event) => {\n        event.preventDefault();\n\n        const formData = new FormData(form);\n        const originalText = button.innerHTML;\n\n        button.disabled = true;\n        button.innerHTML = 'ADDING...';\n        message.style.display = 'none';\n        message.textContent = '';\n\n        try {\n          const response = await fetch('/cart/add.js', {\n            method: 'POST',\n            body: formData,\n            headers: {\n              'Accept': 'application/json'\n            }\n          });\n\n          if (!response.ok) {\n            const errorData = await response.json();\n            throw new Error(errorData.description || 'Unable to add product to cart.');\n          }\n\n          button.innerHTML = 'ADDED';\n          message.textContent = 'Added to cart';\n          message.style.display = 'block';\n\n          document.dispatchEvent(new CustomEvent('cart:refresh'));\n          document.dispatchEvent(new CustomEvent('cart:update'));\n        } catch (error) {\n          message.textContent = error.message || 'Something went wrong.';\n          message.style.display = 'block';\n          button.innerHTML = originalText;\n        } finally {\n          setTimeout(() => {\n            button.disabled = false;\n            button.innerHTML = originalText;\n          }, 1200);\n        }\n      });\n    })();\n  </script>\n\n  <style>\n    .ritual-atc-wrap {\n      margin-top: 16px;\n    }\n\n    .ritual-atc-button {\n      min-width: 280px;\n      border-radius: 999px;\n    }\n\n    .ritual-atc-message {\n      margin-top: 10px;\n      font-size: 12px;\n    }\n  </style>\n{% endif %}"
                  },
