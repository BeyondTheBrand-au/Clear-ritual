                      },
                      "blocks": {
                        "text_B6TJNN": {
                          "type": "text",
                          "name": "t:names.text",
                          "settings": {
                            "text": "<p>Adding a layer of rich, roasted depth, chicory root beautifully grounds the blend. It introduces a comforting, earthy undertone and offers natural prebiotic properties to help support a happy, balanced gut.</p>",
                            "width": "fit-content",
                            "max_width": "normal",
